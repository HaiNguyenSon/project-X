<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PersonChatBot</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-chat-dots-fill-nav-menu" aria-hidden="true"></span> Chat
            </NavLink>
        </div>

        @if (AuthOptions.Value.Enabled)
        {
            <div class="nav-item px-3">
                <form method="post" action="/logout">
                    <button type="submit" class="nav-link btn btn-link text-start">
                        <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Sign out
                    </button>
                </form>
            </div>
        }
    </nav>
</div>

@code {
    [Inject] public Microsoft.Extensions.Options.IOptions<PersonChatBot.Configuration.AuthOptions> AuthOptions { get; set; } = default!;
}

